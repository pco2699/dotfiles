# herdr writes this key (at the top) after first run; declaring it here
# keeps `chezmoi diff` clean
onboarding = false

# Herdr configuration
# Keybindings migrated from tmux (see herdr.dev/docs/configuration)

[keys]
# tmux-style prefix
prefix = "ctrl+a"

# splits: | for side-by-side, - for stacked (plus herdr's default v)
split_vertical = ["prefix+shift+backslash", "prefix+v"]
split_horizontal = ["prefix+minus"]

# vim-style pane focus
focus_pane_left = "prefix+h"
focus_pane_down = "prefix+j"
focus_pane_up = "prefix+k"
focus_pane_right = "prefix+l"

# cycle tabs like tmux windows (prefix+ctrl+h/l), plus herdr defaults,
# plus a direct (no-prefix) shortcut like browser/editor tab switching.
# Ctrl+comma/period have no legacy terminal escape sequence at all (unlike
# letters, which map to classic ASCII control codes) - only terminals with
# a modern keyboard protocol (iTerm2/Kitty/WezTerm/Ghostty) can transmit
# them, and adding Alt doesn't help since there's nothing for the Alt/ESC
# prefix trick to prefix. Windows Terminal (WSL) lacks that protocol and
# also hard-binds ctrl+, to Open Settings, so WSL uses ctrl+alt+left/right
# instead, which has robust escape-sequence support everywhere.
{{- if and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
previous_tab = ["prefix+p", "prefix+ctrl+h", "ctrl+alt+left"]
next_tab = ["prefix+n", "prefix+ctrl+l", "ctrl+alt+right"]
{{- else }}
previous_tab = ["prefix+p", "prefix+ctrl+h", "ctrl+comma"]
next_tab = ["prefix+n", "prefix+ctrl+l", "ctrl+period"]
{{- end }}

# vi-style copy mode (same key as tmux)
copy_mode = "prefix+["

# pane resize is modal in herdr: prefix+r then h/j/k/l
resize_mode = "prefix+r"

[theme]
name = "tokyo-night"

[ui]
# mouse support (tmux: mouse on)
mouse_capture = true

# create new tabs immediately instead of prompting for a name (tmux-style)
prompt_new_tab_name = false

[session]
# restore agent panes when the server restarts (replaces tmux-resurrect/continuum)
resume_agents_on_restore = true
