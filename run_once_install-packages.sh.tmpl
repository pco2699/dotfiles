#!/bin/bash

set -e

echo "Installing packages for {{ .chezmoi.os }} ({{ .osid }})..."

{{- if eq .chezmoi.os "darwin" }}
# macOS (Homebrew)
brew update
brew install fish
brew install neovim
brew install mise
brew install herdr
brew install go
brew install ghq
brew install gh fd ripgrep zoxide bat fzf
# TODO: add powerline

{{- else if eq .osid "linux-ubuntu" }}
# Ubuntu/Debian
if [ ! -f /usr/share/keyrings/githubcli-archive-keyring.gpg ]; then
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | sudo dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg
fi
if [ ! -f /etc/apt/sources.list.d/github-cli.list ]; then
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
fi
sudo apt-add-repository -y ppa:fish-shell/release-3
sudo apt update
sudo apt -y install gpg
sudo apt -y install fish gh zip fd-find ripgrep zoxide bat fzf eza

# fd-find installs the binary as fdfind on Debian/Ubuntu
mkdir -p ~/.local/bin
if [ ! -e ~/.local/bin/fd ]; then
    ln -s "$(command -v fdfind)" ~/.local/bin/fd
fi

# required by mise
sudo apt -y install curl git

# required by python
sudo apt -y install build-essential libssl-dev zlib1g-dev \
    libbz2-dev libreadline-dev libsqlite3-dev curl git \
    libncursesw5-dev xz-utils tk-dev libxml2-dev libxmlsec1-dev libffi-dev liblzma-dev

# install nvim
if [ ! -f ~/.local/bin/nvim ]; then
    mkdir -p ~/.local
    curl -LO https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz
    tar -C ~/.local/ --strip-components 1 -xzf nvim-linux-x86_64.tar.gz
    rm -rf ~/.local/bin/README.md
    rm -rf ~/.local/bin/LICENSE
    rm -rf nvim-linux-x86_64.tar.gz
fi

{{- else if eq .osid "linux-debian" }}
# Debian
if [ ! -f /usr/share/keyrings/githubcli-archive-keyring.gpg ]; then
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | sudo dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg
fi
if [ ! -f /etc/apt/sources.list.d/github-cli.list ]; then
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
fi
sudo apt update
sudo apt -y install gpg
sudo apt -y install fish gh zip fd-find ripgrep zoxide bat fzf eza

# fd-find installs the binary as fdfind on Debian/Ubuntu
mkdir -p ~/.local/bin
if [ ! -e ~/.local/bin/fd ]; then
    ln -s "$(command -v fdfind)" ~/.local/bin/fd
fi

# required by mise
sudo apt -y install curl git

# required by python
sudo apt -y install build-essential libssl-dev zlib1g-dev \
    libbz2-dev libreadline-dev libsqlite3-dev curl git \
    libncursesw5-dev xz-utils tk-dev libxml2-dev libxmlsec1-dev libffi-dev liblzma-dev

# install nvim
if [ ! -f ~/.local/bin/nvim ]; then
    mkdir -p ~/.local
    curl -LO https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz
    tar -C ~/.local/ --strip-components 1 -xzf nvim-linux-x86_64.tar.gz
    rm -rf ~/.local/bin/README.md
    rm -rf ~/.local/bin/LICENSE
    rm -rf nvim-linux-x86_64.tar.gz
fi

{{- else if eq .osid "linux-fedora" }}
# Fedora
sudo dnf install -y dnf-plugins-core
if [ ! -f /etc/yum.repos.d/gh-cli.repo ]; then
    sudo dnf config-manager addrepo --from-repofile=https://cli.github.com/packages/rpm/gh-cli.repo
fi
sudo dnf install -y fish gh zip neovim fzf fd-find ripgrep zoxide bat

# required by mise
sudo dnf install -y curl git

# required by python
sudo dnf install -y gcc make zlib-devel bzip2 bzip2-devel readline-devel \
    sqlite sqlite-devel openssl-devel tk-devel libffi-devel xz-devel

{{- else }}
# Generic Linux - install what we can
echo "Unsupported OS: {{ .osid }}"
echo "Please install packages manually: fish, neovim, gh, fzf, zip"
{{- end }}

# install mise (runtime version manager, replaces asdf)
{{- if ne .chezmoi.os "darwin" }}
if ! command -v mise >/dev/null 2>&1 && [ ! -f ~/.local/bin/mise ]; then
    curl -fsSL https://mise.run | sh
fi
{{- end }}
export PATH="$HOME/.local/bin:$PATH"

{{- if ne .chezmoi.os "darwin" }}
# install herdr (terminal multiplexer, replaces tmux) - installed via brew on macOS
mise use -g herdr@latest
{{- end }}

# ghq setup
mkdir -p ~/.ghq
git config --global ghq.root "~/.ghq"


# install fisher (fish plugin manager)
if [ "$CODESPACES" != true ]; then
    fish -c "curl -sL https://git.io/fisher | source; fisher update" || true

    # install language runtimes with mise
    mise use -g node@latest
    mise use -g python@latest
    mise use -g go@latest
    mise use -g zig@latest
    mise use -g ghq@latest
    {{- if eq .osid "linux-fedora" }}
    mise use -g eza@latest
    {{- end }}
    echo "================================================"
    echo "Installation complete!"
    echo "Run 'chsh -s /usr/bin/fish' to set fish as your default shell"
    echo "================================================"
fi
